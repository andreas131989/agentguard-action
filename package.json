{
  "name": "agentguard-action",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A lightweight GitHub Action that flags risky AI/bot-created pull requests for extra human attention.",
  "main": "dist/index.cjs",
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [
    "github-action",
    "ai",
    "pull-request",
    "risk",
    "ai-agents",
    "developer-tools"
  ],
  "license": "SEE LICENSE IN LICENSE.md",
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.7",
    "eslint": "^9.18.0",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}